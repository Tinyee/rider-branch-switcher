<idea-plugin>
    <id>com.submodule.branchswitcher</id>
    <name>Submodule Branch Switcher</name>
    <vendor url="https://github.com/Tinyee/rider-branch-switcher" email="tinyee@users.noreply.github.com">Tinyee</vendor>
    <resource-bundle>messages.BranchSwitcherBundle</resource-bundle>
    <description><![CDATA[
        One-click switch the main repo and all its submodules to a preset branch combination.
        <br><br>
        <b>Features:</b>
        <ul>
            <li>Save branch combinations (main + submodules) as named presets</li>
            <li>Preflight preview: dry-run table per repo before switching</li>
            <li>Dirty working tree strategies: stash / skip / force</li>
            <li>Auto stash pop when switching back to the original branch</li>
            <li>Derive feature branches on all repos simultaneously</li>
            <li>Rollback to pre-switch state on failure</li>
            <li>Ctrl+Alt+B shortcut for quick preset picker</li>
        </ul>
        Presets are stored in <code>.idea/branch-presets.json</code> — team members can share via git.
        <br><br>
        Settings at <i>File → Settings → Version Control → Submodule Branch Switcher</i>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <actions>
        <action id="SubmoduleBranchSwitcher.SwitchPreset"
                class="com.submodule.branchswitcher.action.SwitchPresetAction"
                text="action.switch.preset.action"
                description="action.switch.preset.action.desc">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt B"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="SubmoduleBranches"
                    anchor="right"
                    icon="AllIcons.Vcs.Branch"
                    factoryClass="com.submodule.branchswitcher.ui.BranchSwitcherToolWindowFactory"/>
        <notificationGroup id="Submodule Branch Switcher"
                           displayType="BALLOON"
                           toolWindowId="SubmoduleBranches"/>
        <errorHandler implementation="com.intellij.diagnostic.JetBrainsMarketplaceErrorReportSubmitter"/>
        <projectConfigurable
            instance="com.submodule.branchswitcher.settings.BranchSwitcherConfigurable"
            displayName="Submodule Branch Switcher"
            parentId="vcs"/>
    </extensions>
</idea-plugin>
