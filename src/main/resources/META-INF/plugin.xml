<idea-plugin>
    <id>com.submodule.branchswitcher</id>
    <name>Submodule Branch Switcher</name>
    <vendor url="https://github.com/jty75/rider-branch-switcher" email="jty75@users.noreply.github.com">jty75</vendor>
    <resource-bundle>messages.BranchSwitcherBundle</resource-bundle>
    <description><![CDATA[
        One-click switch the main repo and all its submodules to a preset branch combo.
        Reads branch presets from .idea/branch-presets.json (auto-created on first run).
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <actions>
        <action id="SubmoduleBranchSwitcher.SwitchPreset"
                class="com.submodule.branchswitcher.action.SwitchPresetAction"
                text="action.switch.preset.action"
                description="action.switch.preset.action.desc">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt B"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="SubmoduleBranches"
                    anchor="right"
                    icon="AllIcons.Vcs.Branch"
                    factoryClass="com.submodule.branchswitcher.ui.BranchSwitcherToolWindowFactory"/>
        <notificationGroup id="Submodule Branch Switcher"
                           displayType="BALLOON"
                           toolWindowId="SubmoduleBranches"/>
        <errorHandler implementation="com.intellij.diagnostic.JetBrainsMarketplaceErrorReportSubmitter"/>
        <projectConfigurable
            instance="com.submodule.branchswitcher.settings.BranchSwitcherConfigurable"
            displayName="Submodule Branch Switcher"
            parentId="vcs"/>
    </extensions>
</idea-plugin>
