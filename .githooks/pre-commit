#!/bin/bash
# Pre-commit hook: run lightweight structural checks before every commit.
# Install: git config core.hooksPath .githooks

set -e

run_gradle() {
    if [ -f "./gradlew.bat" ] && command -v cmd.exe >/dev/null 2>&1; then
        cmd.exe /Q /C gradlew.bat "$@" </dev/null
    else
        ./gradlew "$@" </dev/null
    fi
}

echo "Running quickCheck..."
run_gradle quickCheck --quiet 2>&1

if [ $? -ne 0 ]; then
    echo ""
    echo "quickCheck failed. Fix the issues above before committing."
    echo "To bypass (not recommended): git commit --no-verify"
    exit 1
fi

echo "quickCheck passed."
